package rules

import com.zephyr.rule.model.Person

rule "成年人规则"
    when
        $p : Person(age >= 18, adult == false)
    then
        System.out.println("规则触发: " + $p.getName() + " 是成年人");
        modify($p) { setAdult(true) };
end

rule "未成年人规则"
    when
        $p : Person(age < 18, adult == false)
    then
        System.out.println("规则触发: " + $p.getName() + " 是未成年人");
end